/**
 * @file shift_register_test.c.example
 * @brief Esempio di test per il modulo shift register del manettino
 * 
 * Questo file contiene esempi di utilizzo e test per verificare
 * il corretto funzionamento dello shift register 74HC165.
 * 
 * Per usarlo, rinominare in shift_register_test.c e includere nel progetto.
 */

#include "shift_register.h"
#include "main.h"
#include <stdio.h>

// Buffer per messaggi debug (opzionale, richiede UART configurata)
extern UART_HandleTypeDef huart2;
char debug_msg[100];

/**
 * Test 1: Lettura continua con visualizzazione
 * Mostra il valore grezzo letto dallo shift register
 */
void Test_ContinuousRead(void) {
    uint8_t rawValue = SR_ReadRaw();
    int len = sprintf(debug_msg, "Raw SR Value: 0x%02X (bin: ", rawValue);
    
    // Stampa in binario
    for (int i = 7; i >= 0; i--) {
        debug_msg[len++] = (rawValue & (1 << i)) ? '1' : '0';
    }
    debug_msg[len++] = ')';
    debug_msg[len++] = '\r';
    debug_msg[len++] = '\n';
    debug_msg[len] = '\0';
    
    HAL_UART_Transmit(&huart2, (uint8_t*)debug_msg, len, HAL_MAX_DELAY);
}

/**
 * Test 2: Verifica debouncing
 * Conta quante volte il valore cambia in un intervallo di tempo
 */
void Test_DebounceStability(uint32_t duration_ms) {
    uint32_t startTime = HAL_GetTick();
    uint32_t changeCount = 0;
    int8_t lastPosition = -2;
    
    int len = sprintf(debug_msg, "Testing debounce for %lu ms...\r\n", duration_ms);
    HAL_UART_Transmit(&huart2, (uint8_t*)debug_msg, len, HAL_MAX_DELAY);
    
    while ((HAL_GetTick() - startTime) < duration_ms) {
        SR_ProcessPeriodic();
        
        if (SR_HasChanged()) {
            int8_t currentPosition = SR_GetStablePosition();
            
            if (currentPosition != lastPosition) {
                changeCount++;
                lastPosition = currentPosition;
                
                len = sprintf(debug_msg, "Position changed to: %d\r\n", currentPosition);
                HAL_UART_Transmit(&huart2, (uint8_t*)debug_msg, len, HAL_MAX_DELAY);
            }
        }
        
        HAL_Delay(1);
    }
    
    len = sprintf(debug_msg, "Total changes detected: %lu\r\n", changeCount);
    HAL_UART_Transmit(&huart2, (uint8_t*)debug_msg, len, HAL_MAX_DELAY);
}

/**
 * Test 3: Verifica tutte le posizioni
 * Chiede di ruotare il manettino su tutte le posizioni
 */
void Test_AllPositions(void) {
    uint8_t positionsFound[9] = {0}; // 0-8
    uint32_t timeout = 30000; // 30 secondi
    uint32_t startTime = HAL_GetTick();
    
    int len = sprintf(debug_msg, "Rotate knob through all positions (30s timeout)...\r\n");
    HAL_UART_Transmit(&huart2, (uint8_t*)debug_msg, len, HAL_MAX_DELAY);
    
    while ((HAL_GetTick() - startTime) < timeout) {
        SR_ProcessPeriodic();
        
        if (SR_HasChanged()) {
            int8_t position = SR_GetStablePosition();
            
            if (position >= 0 && position <= 8) {
                if (!positionsFound[position]) {
                    positionsFound[position] = 1;
                    
                    len = sprintf(debug_msg, "✓ Position %d detected\r\n", position);
                    HAL_UART_Transmit(&huart2, (uint8_t*)debug_msg, len, HAL_MAX_DELAY);
                }
            } else if (position == -1) {
                len = sprintf(debug_msg, "✗ Invalid position detected!\r\n");
                HAL_UART_Transmit(&huart2, (uint8_t*)debug_msg, len, HAL_MAX_DELAY);
            }
        }
        
        HAL_Delay(10);
    }
    
    // Riepilogo
    len = sprintf(debug_msg, "\r\nPositions found:\r\n");
    HAL_UART_Transmit(&huart2, (uint8_t*)debug_msg, len, HAL_MAX_DELAY);
    
    for (int i = 0; i <= 8; i++) {
        len = sprintf(debug_msg, "Position %d: %s\r\n", 
                      i, positionsFound[i] ? "YES" : "NO");
        HAL_UART_Transmit(&huart2, (uint8_t*)debug_msg, len, HAL_MAX_DELAY);
    }
}

/**
 * Test 4: Timing di risposta
 * Misura il tempo tra il cambio fisico e il rilevamento
 */
void Test_ResponseTiming(void) {
    int len = sprintf(debug_msg, "Monitoring response time...\r\n");
    HAL_UART_Transmit(&huart2, (uint8_t*)debug_msg, len, HAL_MAX_DELAY);
    
    int8_t lastPosition = SR_GetCurrentPosition();
    uint32_t changeStartTime = 0;
    uint8_t waitingForChange = 0;
    
    for (int testNum = 0; testNum < 10; testNum++) {
        len = sprintf(debug_msg, "\r\nTest %d: Change position now!\r\n", testNum + 1);
        HAL_UART_Transmit(&huart2, (uint8_t*)debug_msg, len, HAL_MAX_DELAY);
        
        // Aspetta che l'utente cambi posizione
        waitingForChange = 1;
        changeStartTime = HAL_GetTick();
        
        while (waitingForChange) {
            SR_ProcessPeriodic();
            
            if (SR_HasChanged()) {
                int8_t newPosition = SR_GetStablePosition();
                
                if (newPosition != lastPosition && newPosition >= 0) {
                    uint32_t responseTime = HAL_GetTick() - changeStartTime;
                    
                    len = sprintf(debug_msg, "Change detected in %lu ms (Pos %d → %d)\r\n", 
                                  responseTime, lastPosition, newPosition);
                    HAL_UART_Transmit(&huart2, (uint8_t*)debug_msg, len, HAL_MAX_DELAY);
                    
                    lastPosition = newPosition;
                    waitingForChange = 0;
                }
            }
            
            // Timeout dopo 10 secondi
            if ((HAL_GetTick() - changeStartTime) > 10000) {
                len = sprintf(debug_msg, "Timeout - no change detected\r\n");
                HAL_UART_Transmit(&huart2, (uint8_t*)debug_msg, len, HAL_MAX_DELAY);
                waitingForChange = 0;
            }
            
            HAL_Delay(1);
        }
        
        HAL_Delay(500); // Pausa tra i test
    }
}

/**
 * Test 5: Stress test - Rotazione veloce
 * Verifica che non ci siano errori con rotazione veloce
 */
void Test_FastRotation(uint32_t duration_ms) {
    uint32_t startTime = HAL_GetTick();
    uint32_t validChanges = 0;
    uint32_t invalidReads = 0;
    
    int len = sprintf(debug_msg, "Stress test: Rotate knob quickly for %lu ms\r\n", duration_ms);
    HAL_UART_Transmit(&huart2, (uint8_t*)debug_msg, len, HAL_MAX_DELAY);
    
    while ((HAL_GetTick() - startTime) < duration_ms) {
        SR_ProcessPeriodic();
        
        if (SR_HasChanged()) {
            int8_t position = SR_GetStablePosition();
            
            if (position >= 0) {
                validChanges++;
            } else {
                invalidReads++;
            }
        }
        
        HAL_Delay(1);
    }
    
    len = sprintf(debug_msg, "\r\nResults:\r\n");
    HAL_UART_Transmit(&huart2, (uint8_t*)debug_msg, len, HAL_MAX_DELAY);
    
    len = sprintf(debug_msg, "Valid changes: %lu\r\n", validChanges);
    HAL_UART_Transmit(&huart2, (uint8_t*)debug_msg, len, HAL_MAX_DELAY);
    
    len = sprintf(debug_msg, "Invalid reads: %lu\r\n", invalidReads);
    HAL_UART_Transmit(&huart2, (uint8_t*)debug_msg, len, HAL_MAX_DELAY);
    
    float errorRate = (invalidReads * 100.0f) / (validChanges + invalidReads);
    len = sprintf(debug_msg, "Error rate: %.2f%%\r\n", errorRate);
    HAL_UART_Transmit(&huart2, (uint8_t*)debug_msg, len, HAL_MAX_DELAY);
}

/**
 * Menu di test interattivo
 * Chiamare questa funzione dal main per eseguire i test
 */
void ShiftRegister_RunTests(void) {
    int len = sprintf(debug_msg, "\r\n=== SHIFT REGISTER TEST SUITE ===\r\n");
    HAL_UART_Transmit(&huart2, (uint8_t*)debug_msg, len, HAL_MAX_DELAY);
    
    len = sprintf(debug_msg, "1. Continuous read test\r\n");
    HAL_UART_Transmit(&huart2, (uint8_t*)debug_msg, len, HAL_MAX_DELAY);
    
    len = sprintf(debug_msg, "2. Debounce stability test\r\n");
    HAL_UART_Transmit(&huart2, (uint8_t*)debug_msg, len, HAL_MAX_DELAY);
    
    len = sprintf(debug_msg, "3. All positions test\r\n");
    HAL_UART_Transmit(&huart2, (uint8_t*)debug_msg, len, HAL_MAX_DELAY);
    
    len = sprintf(debug_msg, "4. Response timing test\r\n");
    HAL_UART_Transmit(&huart2, (uint8_t*)debug_msg, len, HAL_MAX_DELAY);
    
    len = sprintf(debug_msg, "5. Fast rotation stress test\r\n");
    HAL_UART_Transmit(&huart2, (uint8_t*)debug_msg, len, HAL_MAX_DELAY);
    
    len = sprintf(debug_msg, "\r\nRunning all tests...\r\n\r\n");
    HAL_UART_Transmit(&huart2, (uint8_t*)debug_msg, len, HAL_MAX_DELAY);
    
    // Esegui tutti i test
    HAL_Delay(1000);
    
    // Test 1: Letture continue (5 secondi)
    len = sprintf(debug_msg, "\r\n--- Test 1: Continuous Read ---\r\n");
    HAL_UART_Transmit(&huart2, (uint8_t*)debug_msg, len, HAL_MAX_DELAY);
    uint32_t endTime = HAL_GetTick() + 5000;
    while (HAL_GetTick() < endTime) {
        Test_ContinuousRead();
        HAL_Delay(500);
    }
    
    HAL_Delay(1000);
    
    // Test 2: Debounce
    len = sprintf(debug_msg, "\r\n--- Test 2: Debounce Stability ---\r\n");
    HAL_UART_Transmit(&huart2, (uint8_t*)debug_msg, len, HAL_MAX_DELAY);
    Test_DebounceStability(10000);
    
    HAL_Delay(1000);
    
    // Test 3: Tutte le posizioni
    len = sprintf(debug_msg, "\r\n--- Test 3: All Positions ---\r\n");
    HAL_UART_Transmit(&huart2, (uint8_t*)debug_msg, len, HAL_MAX_DELAY);
    Test_AllPositions();
    
    HAL_Delay(1000);
    
    // Test 4: Response timing
    len = sprintf(debug_msg, "\r\n--- Test 4: Response Timing ---\r\n");
    HAL_UART_Transmit(&huart2, (uint8_t*)debug_msg, len, HAL_MAX_DELAY);
    Test_ResponseTiming();
    
    HAL_Delay(1000);
    
    // Test 5: Stress test
    len = sprintf(debug_msg, "\r\n--- Test 5: Fast Rotation Stress Test ---\r\n");
    HAL_UART_Transmit(&huart2, (uint8_t*)debug_msg, len, HAL_MAX_DELAY);
    Test_FastRotation(15000);
    
    len = sprintf(debug_msg, "\r\n=== ALL TESTS COMPLETED ===\r\n");
    HAL_UART_Transmit(&huart2, (uint8_t*)debug_msg, len, HAL_MAX_DELAY);
}

/**
 * Esempio di integrazione nel main.c:
 * 
 * int main(void) {
 *     HAL_Init();
 *     SystemClock_Config();
 *     MX_GPIO_Init();
 *     MX_USART2_UART_Init();
 *     
 *     SR_Init();
 *     
 *     // Decommentare per eseguire i test
 *     // ShiftRegister_RunTests();
 *     
 *     while (1) {
 *         // Uso normale
 *         SR_ProcessPeriodic();
 *         // ...
 *     }
 * }
 */
